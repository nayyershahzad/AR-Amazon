# Google AI/Genkit Configuration
GOOGLE_GENAI_API_KEY=your_google_ai_api_key_here
PROJECT_ID=your_gcp_project_id

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/debtwise_dev"
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/debtwise_test"

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here
BCRYPT_ROUNDS=12

# Banking Integration (Flink/Plaid)
FLINK_CLIENT_ID=your_flink_client_id
FLINK_SECRET=your_flink_secret
FLINK_ENVIRONMENT=sandbox  # sandbox or production

# Payment Processing (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Socket.IO Configuration
SOCKET_PORT=3002

# Logging
LOG_LEVEL=debug